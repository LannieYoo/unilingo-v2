# Flask Configuration
FLASK_ENV=development
FLASK_PORT=8000
FLASK_HOST=127.0.0.1
SECRET_KEY=your-secret-key-change-in-production

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=../logs

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_TRANSLATION=86400
CACHE_TTL_DICTIONARY=604800
CACHE_TTL_AUTOCOMPLETE=3600

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TRANSLATION=100/hour
RATE_LIMIT_DICTIONARY=200/hour
RATE_LIMIT_AUTOCOMPLETE=500/hour
RATE_LIMIT_STT=50/hour

# STT (Speech-to-Text) Configuration
STT_ENABLED=true
STT_ENGINE=faster-whisper
STT_MODEL=medium
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8

# Vosk STT Configuration (for hybrid mode)
VOSK_MODEL_PATH=backend/models/vosk-model-small-en-us-0.15
VOSK_SAMPLE_RATE=16000

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/unilingo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_DB=unilingo
POSTGRES_PORT=5432

# External API Configuration (if needed in future)
# GOOGLE_TRANSLATE_API_KEY=your-api-key
# MYMEMORY_API_KEY=your-api-key
