# Flask Configuration
FLASK_ENV=development
FLASK_PORT=8000
FLASK_HOST=127.0.0.1
SECRET_KEY=your-secret-key-change-in-production

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=../logs

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL_TRANSLATION=86400
CACHE_TTL_DICTIONARY=604800
CACHE_TTL_AUTOCOMPLETE=3600

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TRANSLATION=100/hour
RATE_LIMIT_DICTIONARY=200/hour
RATE_LIMIT_AUTOCOMPLETE=500/hour
RATE_LIMIT_STT=50/hour

# STT (Speech-to-Text) Configuration
STT_ENABLED=true
STT_ENGINE=faster-whisper
STT_MODEL=medium
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8

# External API Configuration (if needed in future)
# GOOGLE_TRANSLATE_API_KEY=your-api-key
# MYMEMORY_API_KEY=your-api-key
