# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Backend API URL
VITE_API_URL=http://localhost:8000

# Backend STT URL for hybrid mode
VITE_BACKEND_STT_URL=http://localhost:8001/api/stt/process-missing

# Admin User Email (user with this email will have admin access)
VITE_ADMIN_USER=admin@example.com
