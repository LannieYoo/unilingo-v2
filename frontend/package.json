{
  "name": "unilingo",
  "version": "1.0.0",
  "description": "UniLingo - Multilingual Translator & Dictionary Desktop App",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "author": "UniLingo",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none vite\" \"wait-on http://localhost:3001 && cross-env VITE_DEV_SERVER_URL=http://localhost:3001 electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "electron:preview": "vite build && electron ."
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/core": "^8.3.1",
    "@huggingface/transformers": "^3.8.1",
    "@react-oauth/google": "^0.13.4",
    "axios": "^1.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "sherpa-onnx-node": "^1.13.0",
    "tesseract.js": "^5.0.4",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^5.0.8",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.unilingo.desktop",
    "productName": "UniLingo",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/models/**"
    ],
    "extraResources": [
      {
        "from": "electron/models/",
        "to": "models/",
        "filter": [
          "*.onnx",
          "*.txt"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
