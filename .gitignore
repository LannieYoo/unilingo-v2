# Agentic tool folders
.agent/
.agents/
.kiro/
.gemini/
.antigravityignore

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build outputs
dist/
frontend/dist/
backend/dist/
build/
*.log

# Environment variables
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*

# Google OAuth credentials (sensitive)
client_secret*.json

# Config files (sensitive - local overrides only)
**/config.local.py

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Documentation (제외)
doc/

# Scripts (제외)
scripts/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# Whisper 모델 캐시 (선택사항)
.whisper_cache/

# Electron
frontend/electron-dist/
frontend/electron/models/*.onnx
frontend/electron/models/*.tar.bz2
frontend/electron/models/*.txt

# sherpa-onnx WASM build files (large binaries tracked by Git LFS)
# .data and .wasm are tracked via Git LFS (see .gitattributes)
frontend/public/sherpa-onnx-wasm-main-vad-asr.worker.js
frontend/public/*.tar.bz2

# Test/hypothesis
.hypothesis/

# Log files
logs/*.log
!logs/.gitkeep

# Large media (exceeds GitHub 100MB limit - keep local only)
docs/*.mp4

# Crawl scratch data and browser profiles (regenerable, may contain secrets)
frontend/crawl/
frontend/crawl/.browser-profile/
frontend/crawl/.browser-profile-apeuni/
frontend/crawl/profiles/
